# ── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Active backend ────────────────────────────────────────────────────────────
# One of: cloudwatch | gcp | azure | grafana | datadog | elastic | otel
TINKER_BACKEND=cloudwatch

# ── Server ────────────────────────────────────────────────────────────────────
TINKER_SERVER_HOST=0.0.0.0
TINKER_SERVER_PORT=8000

# API keys for CLI / Slack bot authentication to THIS server (not to cloud providers).
# Generate a key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Hash it:        python -c "import hashlib,sys; print(hashlib.sha256(sys.argv[1].encode()).hexdigest())" <key>
# Format: JSON array of {hash, subject, roles}
TINKER_API_KEYS=[{"hash":"<sha256-of-key>","subject":"cli","roles":["sre"]}]

# Optional: JWKS URL for SSO/OIDC JWT validation
# TINKER_JWT_JWKS_URL=https://your-idp.com/.well-known/jwks.json
# TINKER_JWT_AUDIENCE=tinker

# ── AWS / CloudWatch ─────────────────────────────────────────────────────────
# In production: attach an IAM role to the ECS task — no env vars needed.
# For local dev with a named profile:
AWS_PROFILE=default
AWS_REGION=us-east-1
# For CI or non-AWS hosting (not recommended — use IAM role instead):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── GCP ──────────────────────────────────────────────────────────────────────
# In production: attach a service account to Cloud Run — no env vars needed.
# For local dev: run `gcloud auth application-default login`
GCP_PROJECT_ID=my-project
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json  # only if ADC doesn't work

# ── Azure ─────────────────────────────────────────────────────────────────────
# In production: enable Managed Identity on Container Apps — no credentials needed.
# For local dev: run `az login`
AZURE_LOG_ANALYTICS_WORKSPACE_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
# AZURE_TENANT_ID=      # only for EnvironmentCredential / Service Principal
# AZURE_CLIENT_ID=      # only for EnvironmentCredential
# AZURE_CLIENT_SECRET=  # avoid — use Managed Identity instead

# ── Grafana Stack (Loki + Prometheus + Tempo) ─────────────────────────────────
GRAFANA_LOKI_URL=http://loki:3100
GRAFANA_PROMETHEUS_URL=http://prometheus:9090
GRAFANA_TEMPO_URL=http://tempo:3200
# Grafana Cloud (replaces the above URLs + adds auth):
# GRAFANA_LOKI_URL=https://<id>.grafana.net/loki
# GRAFANA_PROMETHEUS_URL=https://<id>.grafana.net/prometheus
# GRAFANA_TEMPO_URL=https://<id>.grafana.net/tempo
# GRAFANA_API_KEY=glc_...
# Self-hosted with auth:
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=...

# ── Datadog ───────────────────────────────────────────────────────────────────
# DATADOG_API_KEY=
# DATADOG_APP_KEY=
# DATADOG_SITE=datadoghq.com   # EU: datadoghq.eu

# ── Elasticsearch / OpenSearch (optional) ─────────────────────────────────────
# ELASTICSEARCH_URL=https://localhost:9200
# ELASTICSEARCH_API_KEY=

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
SLACK_ALERTS_CHANNEL=#incidents

# ── GitHub (for PR creation) ─────────────────────────────────────────────────
GITHUB_TOKEN=ghp_
GITHUB_REPO=your-org/your-repo

# ── Codebase ──────────────────────────────────────────────────────────────────
TINKER_REPO_PATH=/path/to/your/repo

# ── Monitoring loop ───────────────────────────────────────────────────────────
TINKER_POLL_INTERVAL_SECONDS=60
TINKER_ANOMALY_COOLDOWN_MINUTES=30

# ── Agent behaviour ───────────────────────────────────────────────────────────
TINKER_DEFAULT_MODEL=claude-sonnet-4-6
TINKER_DEEP_RCA_MODEL=claude-opus-4-6
TINKER_LOG_LEVEL=INFO
