{
  "mcpServers": {
    "tinker": {
      "_comment": "Remote MCP — use this when the Tinker server is deployed. Replaces all the local servers below.",
      "_transport": "sse",
      "_url": "https://tinker.your-company.internal/mcp/sse",
      "_headers": {
        "Authorization": "Bearer ${TINKR_API_TOKEN}"
      }
    },

    "tinker-cloudwatch": {
      "_comment": "Local stdio MCP — use during development before the server is deployed.",
      "command": "tinker-cloudwatch-mcp",
      "env": {
        "AWS_PROFILE": "prod-readonly",
        "AWS_REGION": "us-east-1"
      }
    },

    "tinker-gcp": {
      "command": "tinker-gcp-mcp",
      "env": {
        "GCP_PROJECT_ID": "${GCP_PROJECT_ID}"
      }
    },

    "tinker-azure": {
      "command": "tinker-azure-mcp",
      "env": {
        "AZURE_LOG_ANALYTICS_WORKSPACE_ID": "${AZURE_LOG_ANALYTICS_WORKSPACE_ID}",
        "AZURE_SUBSCRIPTION_ID": "${AZURE_SUBSCRIPTION_ID}",
        "AZURE_RESOURCE_GROUP": "${AZURE_RESOURCE_GROUP}"
      }
    },

    "tinker-grafana": {
      "command": "tinker-grafana-mcp",
      "env": {
        "GRAFANA_LOKI_URL": "${GRAFANA_LOKI_URL}",
        "GRAFANA_PROMETHEUS_URL": "${GRAFANA_PROMETHEUS_URL}",
        "GRAFANA_TEMPO_URL": "${GRAFANA_TEMPO_URL}",
        "GRAFANA_API_KEY": "${GRAFANA_API_KEY}"
      }
    },

    "tinker-datadog": {
      "command": "tinker-datadog-mcp",
      "env": {
        "DATADOG_API_KEY": "${DATADOG_API_KEY}",
        "DATADOG_APP_KEY": "${DATADOG_APP_KEY}",
        "DATADOG_SITE": "${DATADOG_SITE:-datadoghq.com}"
      }
    },

    "tinker-elastic": {
      "command": "tinker-elastic-mcp",
      "env": {
        "ELASTICSEARCH_URL": "${ELASTICSEARCH_URL}",
        "ELASTICSEARCH_API_KEY": "${ELASTICSEARCH_API_KEY}"
      }
    },

    "tinker-github": {
      "command": "tinker-github-mcp",
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "GITHUB_REPO": "${GITHUB_REPO}",
        "TINKR_REPO_PATH": "${TINKR_REPO_PATH}"
      }
    }
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*create_pr|.*apply_fix",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[tinker] ⚠️  Write operation — ensure /approve was given before proceeding.' >&2"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "tinker.*",
        "hooks": [
          {
            "type": "command",
            "command": "tinker audit-log --tool \"${TOOL_NAME}\" --session \"${SESSION_ID}\" 2>/dev/null || true"
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "tinker-cloudwatch:cloudwatch_query_logs",
      "tinker-cloudwatch:cloudwatch_get_metrics",
      "tinker-cloudwatch:cloudwatch_detect_anomalies",
      "tinker-gcp:gcp_query_logs",
      "tinker-gcp:gcp_get_metrics",
      "tinker-gcp:gcp_detect_anomalies",
      "tinker-azure:azure_query_logs",
      "tinker-azure:azure_get_metrics",
      "tinker-azure:azure_detect_anomalies",
      "tinker-grafana:loki_query_logs",
      "tinker-grafana:prometheus_get_metrics",
      "tinker-grafana:tempo_search_traces",
      "tinker-grafana:grafana_detect_anomalies",
      "tinker-datadog:datadog_query_logs",
      "tinker-datadog:datadog_get_metrics",
      "tinker-datadog:datadog_search_traces",
      "tinker-datadog:datadog_detect_anomalies",
      "tinker-elastic:elastic_query_logs",
      "tinker-elastic:elastic_get_metrics",
      "tinker-elastic:elastic_detect_anomalies",
      "tinker-github:github_get_file",
      "tinker-github:github_search_code",
      "tinker-github:github_recent_commits",
      "tinker-github:github_blame",
      "tinker:query_logs",
      "tinker:get_recent_errors",
      "tinker:get_metrics",
      "tinker:detect_anomalies",
      "tinker:get_file",
      "tinker:search_code",
      "tinker:suggest_fix"
    ],
    "deny": [
      "tinker-github:github_create_pr",
      "tinker:apply_fix"
    ]
  }
}
